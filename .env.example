# ===== 生产环境变量（docker compose 会自动读取本目录下的 .env）=====
# Neo4j 密码（强密码！容器内部使用）
NEO4J_PASSWORD=请改成强密码

# JWT 密钥：务必改成一长串随机值，可用 openssl rand -hex 32 生成
JWT_SECRET=请改成32位以上随机字符串

# 通义千问（阿里云百炼）API-KEY；留空则用内置示例三元组+模板演示
QWEN_API_KEY=
QWEN_TEXT_MODEL=qwen-plus

# 允许的前端来源（同域 Nginx 部署可留空）。例：https://yourdomain.com
FRONTEND_ORIGIN=
